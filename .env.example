# Copy to `.env` (gitignored) and adjust. NEVER commit real secrets.

# Host directory containing your GGUF models (mounted read-only into llama.cpp).
MODELS_DIR=/home/youruser/ml-models

# Tier-0 router model filename inside MODELS_DIR.
E4B_MODEL=gemma-4-E4B-it-Q4_K_M.gguf

# Active use-case (folder under usecases/).
AGENT_USECASE=tienda
